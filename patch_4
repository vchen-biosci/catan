            self.own_deck = [print_own_deck, "pod"]


    available_commands = ["ccs", "ert", "end game", "lbc", "lcd", "start game", "inf", "cr", "ru", "roll"]

    ##for the record, im not sure if im going to use the rest of this or just process the values differently
    ##what i mean by this is: I can choose to process unavailable commands either post-recieving or simply filter out unavailable commands immediately, which is what this aims to achieve
    
    game_only_commands = ["end_game", "lcd"]

    no_game_commands = []
    for i in available_commands:
        if i not in game_only_commands:
            no_game_commands.append(i)

    class Game_States:
        def __init__(self):
            self.in_game = available_commands.remove("start game")
            self.no_game = no_game_commands

    return available_commands, Game_States
    


