def get_number_of_players():

    loop = True
    while loop:
        try:
            number_of_players = int(input())
            while not isinstance(number_of_players, int) or (number_of_players != 3 or number_of_players != 4):
                print("Hi, please enter it as a whole integer of either 3 and 4!")
                number_of_players = int(input())
                loop = False
            
        except TypeError:
            print("Hi, are you sure that your variable is written in arabic numerals? ^^")

    return number_of_players

