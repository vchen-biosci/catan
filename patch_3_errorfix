def get_player_names(number_of_players : int):
    
    name_list = []

    for i in range(number_of_players):

        loop = True
        while loop:
            name = input(f"Player {i+1}, what's your name?")
            repeat = input("Are you sure?")
            if repeat.lower() == "y":
                loop = False
            if repeat.lower() == "n":
                pass
            else:
                print("Type either 'Y' or 'N', silly kid!")
        
        name_list.append(name)

    return name_list

